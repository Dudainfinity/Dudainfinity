<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= @title %></title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main>
      <h1><%= @title %></h1>
      <section class="chart-container">
        <canvas id="coinsChart" aria-label="Gráfico de moedas" role="img"></canvas>
      </section>
      <p>Quero rodar esse gráfico.</p>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
      const labels = <%= @labels.to_json %>;
      const values = <%= @values.to_json %>;

      const ctx = document.getElementById('coinsChart');
      new Chart(ctx, {
        type: 'line',
        data: {
          labels: labels,
          datasets: [{
            label: 'Moedas',
            data: values,
            borderColor: '#2563eb',
            backgroundColor: 'rgba(37, 99, 235, 0.2)',
            borderWidth: 2,
            tension: 0,
            pointRadius: 4,
            pointHoverRadius: 5,
            fill: false
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              display: false
            }
          },
          scales: {
            y: {
              beginAtZero: true,
              ticks: {
                stepSize: 1
              }
            }
          }
        }
      });
    </script>
  </body>
</html>
